#!/usr/bin/env sh

CONTAINER_NAME="nixenv"

if command -v podman >/dev/null 2>&1; then
    ENGINE="podman"
elif command -v docker >/dev/null 2>&1; then
    ENGINE="docker"
else
    echo "Error: Neither podman nor docker could be resolved in your PATH! (っ´;ω;｀c)"
    exit 1
fi

show_help() {
    echo "Usage: nixenv [create|start|pull|help]"
    echo ""
    echo "Current Engine: $ENGINE"
    echo ""
    echo "Commands:"
    echo "  create   Provision a new dev environment"
    echo "  start    Attach to the container or exec into it if already active"
    echo "  pull     Fetching the image"
    echo "  help     Display this system architecture matrix"
}

case "$1" in
    create)
        echo "Creating new container via $ENGINE: $CONTAINER_NAME... (っ´ω｀c)"
        $ENGINE run -it \
          --network host \
          --name "$CONTAINER_NAME" "$CONTAINER_NAME"
        ;;

    start)
        # Check if the container file node exists at all in the engine state
        if ! $ENGINE ps -a --format '{{.Names}}' | grep -Eq "^${CONTAINER_NAME}$"; then
            echo "Error: Container '$CONTAINER_NAME' does not exist yet. Run 'nixenv create' first! (っ´;ω;｀c)"
            exit 1
        fi

        # Inspect the running status of the container environment
        IS_RUNNING=$($ENGINE inspect -f '{{.State.Running}}' "$CONTAINER_NAME" 2>/dev/null)

        if [ "$IS_RUNNING" = "true" ]; then
            echo "Container is already active. Executing internal fish shell session... ~ ♡"
            $ENGINE exec -it "$CONTAINER_NAME" /usr/bin/fish
        else
            echo "Starting stopped container instance... (っ´>ω<｀c)"
            $ENGINE start -ai "$CONTAINER_NAME"
        fi
        ;;

    pull)
        echo "Fetching the container image..."
        $ENGINE pull docker.io/infraflakes/nixenv:latest
        ;;

    help|--help|-h)
        show_help
        ;;

    *)
        echo "Error: Invalid command pattern '$1'."
        show_help
        exit 1
        ;;
esac
