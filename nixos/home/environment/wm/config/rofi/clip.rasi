@import "~/.config/rofi/config.rasi"

window {
  width:          1500px;
  height:         900px;
}

entry {
  width: 50%; 
  placeholder: "  CTRL+Del to wipe one entry     SUPER+Del to wipe all entry";
}

listview {
  layout: vertical; 
  flow: horizontal; 
  columns: 2;
  lines: 8;
  fixed-columns: true; 
}

element {
  padding: 12px 16px; 
  border-radius: 10px;
}
