#!/usr/bin/env bash

set -e

DIR="$HOME/Pictures/Screenshots"
TIME=$(date "+%Y-%m-%d_%H-%M-%S")
FILE="${DIR}/Screenshot_${TIME}_${RANDOM}.png"
NOTIFY_CMD="notify-send -h string:x-canonical-private-synchronous:shot-notify -u low"

mkdir -p "$DIR"

notify_view() {
    if [[ -f "$FILE" ]]; then
        $NOTIFY_CMD "Screenshot Taken" "$FILE"
    else
        $NOTIFY_CMD "Screenshot Failed" "File was not saved."
    fi
}

# --- THE MAGIC UNIFIER FUNCTION ---
# Grabs all visible window rectangles depending on what compositor you run
get_window_geometry() {
    # 1. Try Sway
    if command -v swaymsg &>/dev/null && swaymsg -t get_tree &>/dev/null; then
        swaymsg -t get_tree | jq -r '.. | ((.nodes? + .floating_nodes?) // empty)[] | select(.pid and .visible) | .rect | "\(.x),\(.y) \(.width)x\(.height)"'
    
    # 2. Try Hyprland
    elif command -v hyprctl &>/dev/null && hyprctl monitors &>/dev/null; then
        hyprctl clients -j | jq -r '.[] | select(.hidden | not) | "\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])"'
    
    # 3. Universal Fallback via XDG Desktop Portal (Slower, but works on GNOME/KDE/etc)
    elif command -v ashpd-dbus-runner &>/dev/null || command -v gdbus &>/dev/null; then
        # If we can't map windows layout, let slurp act like regular region select
        echo ""
    fi
}

shotnow() {
    grim "$FILE"
    wl-copy < "$FILE"
    notify_view
}

shotwindow() {
    # Get layout map from our unifier function
    local map
    map=$(get_window_geometry)

    if [[ -n "$map" ]]; then
        # Feed the window layout boxes to slurp so it snaps to them
        GEOM=$(echo "$map" | slurp)
    else
        # Fallback if window tree couldn't be parsed: standard crosshair drag
        $NOTIFY_CMD "Window Mode" "Universal fallback: Click and drag over your window."
        GEOM=$(slurp)
    fi

    if [[ -n "$GEOM" ]]; then
        grim -g "$GEOM" "$FILE"
        wl-copy < "$FILE"
        notify_view
    fi
}

shotswappy() {
    if ! command -v swappy &>/dev/null; then
        $NOTIFY_CMD "Error" "swappy is not installed."
        exit 1
    fi

    if GEOM=$(slurp); then
        grim -g "$GEOM" - | swappy -f - -o "$FILE"
        if [[ -f "$FILE" ]]; then
            wl-copy < "$FILE"
            notify_view
        fi
    fi
}

# Pre-flight check for base tools
for tool in grim slurp wl-copy jq; do
    if ! command -v "$tool" &>/dev/null; then
        $NOTIFY_CMD "Error" "$tool is required but missing."
        exit 1
    fi
done

case "$1" in
    --now)    shotnow ;;
    --window) shotwindow ;;
    --swappy) shotswappy ;;
    *)
        echo "Usage: ${0##*/} [ --now | --window | --swappy ]"
        exit 1
        ;;
esac
