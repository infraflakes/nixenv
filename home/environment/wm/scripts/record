#!/usr/bin/env bash

# Configuration
DIR="$HOME/Videos/Recordings"
TIME=$(date "+%Y-%m-%d_%H-%M-%S")
FILE="${DIR}/Recording_${TIME}.mp4"
NOTIFY_CMD="notify-send -h string:x-canonical-private-synchronous:rec-notify -u normal"
TMP_PATH_FILE="/tmp/current_recording_path"

mkdir -p "$DIR"

# Pre-flight check for required tools
for tool in wf-recorder slurp jq swaymsg wl-copy rofi; do
    if ! command -v "$tool" &>/dev/null; then
        $NOTIFY_CMD "Error" "Missing required tool: $tool"
        exit 1
    fi
done

# Community Goldilocks encoder settings
ENCODER_ARGS=(
    -r 60             # Strict frame rate constraint
    -c libx264 
    -x yuv420p 
    -p crf=22 
    -p preset=faster
    -p tune=stillimage   # Sharp layout tuning for UI elements
)

# Helper to check if record process is currently active
is_recording() {
    pgrep -x "wf-recorder" > /dev/null
}

# Dynamic Context-Aware Menu Setup
show_menu() {
    if is_recording; then
        # Menu displayed ONLY while recording
        options="🛑 Stop & Save Recording\n❌ Cancel & Delete Video"
        selection=$(echo -e "$options" | rofi -config ~/.config/rofi/record.rasi -dmenu -i -p "Recording Active:")
        
        case "$selection" in
            *"Stop"*)
                $NOTIFY_CMD "Recording" "Finalizing and encoding stream..."
                pkill -INT -x "wf-recorder"
                ;;
            *"Cancel"*)
                if [[ -f "$TMP_PATH_FILE" ]]; then
                    local active_file
                    active_file=$(cat "$TMP_PATH_FILE")
                    pkill -KILL -x "wf-recorder" # Ungraceful kill to stop writing instantly
                    rm -f "$active_file"
                    rm -f "$TMP_PATH_FILE"
                    $NOTIFY_CMD "Recording Canceled" "Video file has been purged."
                else
                    pkill -KILL -x "wf-recorder"
                    $NOTIFY_CMD "Recording Canceled" "Process stopped."
                fi
                exit 0
                ;;
        esac
    else
        # Menu displayed ONLY when idle
        options="Desktop Options:\n🖥️ Record Full Screen\n🪟 Record Selected Window\n\nMultimedia Options:\n🎙️ Record Full Screen + Audio\n📻 Record Selected Window + Audio"
        selection=$(echo -e "$options" | rofi -config ~/.config/rofi/record.rasi -dmenu -i -p "Select Action:")
        
        case "$selection" in
            *"Full Screen"*)
                [[ "$selection" == *"Audio"* ]] && start_recording "now" "audio" || start_recording "now"
                ;;
            *"Selected Window"*)
                [[ "$selection" == *"Audio"* ]] && start_recording "window" "audio" || start_recording "window"
                ;;
        esac
    fi
}

start_recording() {
    local mode=$1
    local audio=$2
    local cmd_args=("${ENCODER_ARGS[@]}")

    # Capture internal system desktop sound, ignoring the microphone entirely
    if [[ "$audio" == "audio" ]]; then
        # @DEFAULT_AUDIO_SINK@.monitor targets whatever speakers/headphones are currently active
        cmd_args+=("--audio-device" "@DEFAULT_AUDIO_SINK@.monitor")
    fi

    case "$mode" in
        now)
            echo "$FILE" > "$TMP_PATH_FILE"
            $NOTIFY_CMD "Recording Started" "Capturing desktop canvas..."
            wf-recorder "${cmd_args[@]}" -f "$FILE"
            ;;
        window)
            GEOM=$(swaymsg -t get_tree | jq -r '.. | select(.pid? and .visible?) | .rect | "\(.x),\(.y) \(.width)x\(.height)"' | slurp)
            if [[ -z "$GEOM" ]]; then
                $NOTIFY_CMD "Recording Canceled" "No window surface targeted."
                exit 0
            fi
            echo "$FILE" > "$TMP_PATH_FILE"
            $NOTIFY_CMD "Recording Started" "Capturing targeted application window..."
            wf-recorder -g "$GEOM" "${cmd_args[@]}" -f "$FILE"
            ;;
    esac

    # Post-Execution: Executes automatically when wf-recorder closes via SIGINT
    # Prevents triggering if user explicitly executed a 'Cancel & Delete' command
    if [[ -f "$TMP_PATH_FILE" && -f "$FILE" ]]; then
        echo "$FILE" | wl-copy
        $NOTIFY_CMD "Recording Saved" "$FILE\n(Path copied to clipboard)"
        rm -f "$TMP_PATH_FILE"
    fi
}

# Allow launching directly via programmatic flags (hotkeys) or fall back to Rofi
if [[ -n "$1" ]]; then
    case "$1" in
        --now)          start_recording "now" ;;
        --window)       start_recording "window" ;;
        --now-audio)    start_recording "now" "audio" ;;
        --window-audio) start_recording "window" "audio" ;;
        *) echo "Usage: ${0##*/} [ --now | --window | --now-audio | --window-audio ] or run with no args for UI." ;;
    esac
else
    show_menu
fi
