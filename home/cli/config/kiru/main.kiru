var shell workdir = `echo $HOME`;
var string kiru_dir = `${workdir}/kiru`;

import `${kiru_dir}/.kiru/main.kiru`;

pr kiru [
  url = `git@github.com:infraflakes/kiru.git`
  dir = $kiru_dir
  sync = `clone`
  branch = `dev`
] {}

pr portfolio [
  url = `git@github.com:infraflakes/infraflakes.github.io.git`
  dir = `portfolio`
  sync = `ignore`
] {}

pr srwc [
  url = `https://github.com/infraflakes/srwc.git`
  dir = `srwc`
  sync = `ignore`
  branch = `architectural-cleanups`
] {}
